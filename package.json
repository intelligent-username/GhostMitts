{
  "name": "bun-react-template",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "start": "NODE_ENV=production bun src/index.ts",
    "deploy": "wrangler deploy",
    "preview:worker": "wrangler dev",
    "api:dev": "bunx wrangler dev --config worker/wrangler.toml",
    "api:deploy": "bunx wrangler deploy --config worker/wrangler.toml",
    "api:tail": "bunx wrangler tail --config worker/wrangler.toml"
  },
  "dependencies": {
    "react": "^19",
    "react-dom": "^19",
    "@tursodatabase/serverless": "^1.1.3",
    "wrangler": "^4.72.0"
  },
  "devDependencies": {
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@types/bun": "latest",
    "@vitejs/plugin-react": "^4.7.0",
    "sirv": "^3.0.1",
    "vite": "^7.0.0",
    "vite-plugin-static-copy": "^3.1.0"
  }
}
