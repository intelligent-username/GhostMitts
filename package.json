{
  "name": "bun-react-template",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "bun --hot src/index.ts",
    "build": "bun build ./src/index.html --outdir=dist --sourcemap --target=browser --minify --define:process.env.NODE_ENV='\"production\"' --define:BUN_PUBLIC_API_BASE='\"https://ghostmitts-api.varakt-dev.workers.dev\"' --env='BUN_PUBLIC_*'",
    "start": "NODE_ENV=production bun src/index.ts",
    "deploy": "wrangler deploy",
    "preview": "wrangler dev",
    "api:dev": "bunx wrangler dev --config worker/wrangler.toml",
    "api:deploy": "bunx wrangler deploy --config worker/wrangler.toml",
    "api:tail": "bunx wrangler tail --config worker/wrangler.toml"
  },
  "dependencies": {
    "react": "^19",
    "react-dom": "^19",
    "@tursodatabase/serverless": "^1.1.3",
    "wrangler": "^4.72.0"
  },
  "devDependencies": {
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@types/bun": "latest"
  }
}
